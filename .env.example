# ============================================================================
# MARKET CRASH PREDICTOR - CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# ============================================================================

# ============================================================================
# API CONFIGURATION (REQUIRED)
# ============================================================================
# Get your free FRED API key at: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY= 547eaa8594ba77f00c821095c8e8482a

# Alpha Vantage API key (optional - for alternative data)
ALPHA_VANTAGE_API_KEY=Y6O2ZZ4NAO1EQZGE

# ============================================================================
# NOTE: Put/Call Ratio and Margin Debt are now FREE!
# ============================================================================
# - Put/Call Ratio: Calculated automatically from SPY options (yfinance) - FREE
# - Margin Debt: Downloaded automatically from FINRA Excel file - FREE
# No additional API keys needed for these data sources!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite (default - for development)
DATABASE_URL=sqlite:///data/market_crash.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/market_crash
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ============================================================================
# REDIS CONFIGURATION (for caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=300

# ============================================================================
# MLFLOW CONFIGURATION (model versioning)
# ============================================================================
MLFLOW_TRACKING_URI=file://data/mlflow
MLFLOW_EXPERIMENT_NAME=market_crash_prediction
MLFLOW_REGISTRY_URI=file://data/mlflow

# ============================================================================
# API SERVER CONFIGURATION (FastAPI)
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# ============================================================================
# DATA COLLECTION CONFIGURATION
# ============================================================================
# FRED API rate limiting (requests per minute)
FRED_RATE_LIMIT=120

# API timeout settings (seconds)
FRED_TIMEOUT=30
YAHOO_TIMEOUT=30

# Retry configuration
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
# Daily pipeline execution time (24-hour format)
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0

# ============================================================================
# FEATURE ENGINEERING CONFIGURATION
# ============================================================================
# Technical indicator windows (in days/periods)
VOLATILITY_WINDOW=20
MOMENTUM_WINDOW=200
DRAWDOWN_WINDOW=252

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
# Random seed for reproducibility
RANDOM_STATE=42

# Train/test/validation split ratios
TEST_SIZE=0.2
VALIDATION_SIZE=0.1

# ============================================================================
# DATA VALIDATION CONFIGURATION
# ============================================================================
# Minimum data quality score (0-1)
MIN_DATA_QUALITY_SCORE=0.95

# Maximum allowed missing data percentage
MAX_MISSING_PERCENTAGE=5.0

# ============================================================================
# ALERT CONFIGURATION (Optional)
# ============================================================================
# Email alert settings (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
ALERT_EMAIL_FROM=aetherstoneverntures@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password_here

# SMS alert settings (Twilio - optional)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_FROM=+1234567890

# Alert recipients (comma-separated)
ALERT_EMAIL_RECIPIENTS=recipient@example.com
ALERT_SMS_RECIPIENTS=+1234567890

# ============================================================================
# DASHBOARD CONFIGURATION
# ============================================================================
DASHBOARD_PORT=8501
DASHBOARD_THEME=light

# ============================================================================
# MODEL THRESHOLDS
# ============================================================================
# Crash prediction threshold (0.0 - 1.0)
CRASH_PROBABILITY_THRESHOLD=0.5

# Bottom prediction threshold (0.0 - 1.0)
BOTTOM_PREDICTION_THRESHOLD=0.5

# ============================================================================
# BACKFILL CONFIGURATION
# ============================================================================
# Historical data backfill date range
BACKFILL_START_DATE=1970-01-01
BACKFILL_END_DATE=2026-03-30

# ============================================================================
# FEATURE ENGINEERING THRESHOLDS
# ============================================================================
# Bry-Boschan algorithm parameters
BOSCHAN_MIN_DURATION=15
BOSCHAN_MIN_AMPLITUDE=0.15
BOSCHAN_PHASE_LENGTH=6

# Feature correlation threshold
FEATURE_CORRELATION_THRESHOLD=0.95

# Feature normalization method (standard, minmax, or none)
FEATURE_NORMALIZATION_METHOD=standard

# Crash detection threshold (drawdown percentage)
CRASH_DRAWDOWN_THRESHOLD=0.20

# ============================================================================
# ADVANCED ML MODEL CONFIGURATION
# ============================================================================
# LSTM/GRU Configuration
LSTM_UNITS=128
LSTM_LAYERS=3
LSTM_DROPOUT=0.3
LSTM_SEQUENCE_LENGTH=60
LSTM_BATCH_SIZE=32
LSTM_EPOCHS=100
LSTM_EARLY_STOPPING_PATIENCE=15

# Transformer Configuration
TRANSFORMER_D_MODEL=128
TRANSFORMER_NHEAD=8
TRANSFORMER_NUM_LAYERS=4
TRANSFORMER_DROPOUT=0.2

# XGBoost/LightGBM/CatBoost Configuration
XGBOOST_MAX_DEPTH=6
XGBOOST_N_ESTIMATORS=500
XGBOOST_LEARNING_RATE=0.01
XGBOOST_EARLY_STOPPING_ROUNDS=50

# Optuna Hyperparameter Optimization
OPTUNA_N_TRIALS=100
OPTUNA_TIMEOUT=3600

# Walk-Forward Validation
WALK_FORWARD_WINDOW_SIZE=252
WALK_FORWARD_STEP_SIZE=21
WALK_FORWARD_MIN_TRAIN_SIZE=1260

# ============================================================================
# MONITORING & ALERTING CONFIGURATION
# ============================================================================
ENABLE_MONITORING=true
PROMETHEUS_PORT=9090
SENTRY_DSN=
ALERT_ON_PIPELINE_FAILURE=true

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESS=true

# ============================================================================
# SYNTHETIC DATA CONFIGURATION
# ============================================================================
# WARNING: These are proxies, not real data!
USE_SYNTHETIC_PUT_CALL_RATIO=true
USE_SYNTHETIC_MARGIN_DEBT=true
WARN_SYNTHETIC_DATA=true

# ============================================================================
# TESTING CONFIGURATION
# ============================================================================
# Test coverage minimum percentage
MIN_TEST_COVERAGE=85
SKIP_CONFIG_VALIDATION=false

# ============================================================================
# PERFORMANCE TARGETS
# ============================================================================
# Model performance targets
CRASH_PREDICTION_AUC_TARGET=0.85
CRASH_PREDICTION_ACCURACY_TARGET=0.85
CRASH_DETECTION_RECALL_TARGET=0.75
FALSE_ALARM_RATE_TARGET=0.20

# Bottom prediction targets
BOTTOM_PREDICTION_ACCURACY_TARGET=0.85
BOTTOM_PREDICTION_DAYS_TOLERANCE=30
RECOVERY_TIME_R2_TARGET=0.75

# System performance targets (seconds)
DATA_COLLECTION_MAX_TIME=300
FEATURE_GENERATION_MAX_TIME=300
MODEL_INFERENCE_MAX_TIME=300
DASHBOARD_LOAD_MAX_TIME=120

